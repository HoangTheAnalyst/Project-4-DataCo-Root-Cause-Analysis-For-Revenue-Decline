expression 'Country Translation' =
		let
		    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Column1 = _t, Column2 = _t]),
		    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Column1", type text}, {"Column2", type text}}),
		    #"Renamed Columns" = Table.RenameColumns(#"Changed Type",{{"Column1", "Country(Spanish)"}, {"Column2", "Country(English)"}})
		in
