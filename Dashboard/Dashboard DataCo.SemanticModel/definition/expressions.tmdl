expression DataCoTransMain = ```
		let
		    Source = DataCoTransRoot,
		    #"Renamed Columns" = Table.RenameColumns(Source,{{"Type", "Payment Type"}}),
		    #"Capitalized Payment Type" = Table.TransformColumns(#"Renamed Columns",{{"Payment Type", Text.Proper, type text}}),
		    #"Filtered Rows" = Table.SelectRows(#"Capitalized Payment Type", each true),
		    #"New Delivery Status : Days for shipping = days for shipment = 0 -> Immediate" = Table.AddColumn(#"Filtered Rows", "Custom", each if [#"Days for shipping (real)"] = 0 and [#"Days for shipment (scheduled)"] = 0 
		then "Immediate" 
		else [Delivery Status]),
		    #"Reordered Columns" = Table.ReorderColumns(#"New Delivery Status : Days for shipping = days for shipment = 0 -> Immediate",{"Payment Type", "Days for shipping (real)", "Days for shipment (scheduled)", "Benefit per order", "Sales per customer", "Custom", "Delivery Status", "Late_delivery_risk", "Category Id", "Category Name", "Customer City", "Customer Country", "Customer Email", "Customer Fname", "Customer Id", "Customer Lname", "Customer Password", "Customer Segment", "Customer State", "Customer Street", "Customer Zipcode", "Department Id", "Department Name", "Latitude", "Longitude", "Market", "Order City", "Order Country", "Order Customer Id", "order date (DateOrders)", "Order Id", "Order Item Cardprod Id", "Order Item Discount", "Order Item Discount Rate", "Order Item Id", "Order Item Product Price", "Order Item Profit Ratio", "Order Item Quantity", "Sales", "Order Item Total", "Order Profit Per Order", "Order Region", "Order State", "Order Status", "Order Zipcode", "Product Card Id", "Product Category Id", "Product Description", "Product Image", "Product Name", "Product Price", "Product Status", "shipping date (DateOrders)", "Shipping Mode"}),
		    #"Removed Old Delivery Status" = Table.RemoveColumns(#"Reordered Columns",{"Delivery Status"}),
		    #"Renamed Columns1" = Table.RenameColumns(#"Removed Old Delivery Status",{{"Custom", "Delivery Status"}}),
		    #"Remove Delivery Risk Columns, Department, Category, Product Image & Product Description Columns" = Table.RemoveColumns(#"Renamed Columns1",{"Late_delivery_risk", "Category Id", "Category Name", "Department Id", "Department Name", "Product Category Id", "Product Description", "Product Image"}),
		    #"Capitalized Product Name" = Table.TransformColumns(#"Remove Delivery Risk Columns, Department, Category, Product Image & Product Description Columns",{{"Product Name", Text.Proper, type text}}),
		    #"Added New Category Column" = Table.AddColumn(#"Capitalized Product Name", "Custom", each let
		    name = Text.Lower([Product Name]), 
		    category = 
		        if Text.Contains(name, "golf") or Text.Contains(name, "putter") or Text.Contains(name, "titleist") or Text.Contains(name, "bridgestone") or Text.Contains(name, "taylormade") then "Golf & Equipment"
		        else if Text.Contains(name, "shoe") or Text.Contains(name, "cleat") or Text.Contains(name, "slide") or Text.Contains(name, "sock") then "Footwear"
		        else if Text.Contains(name, "nike") or Text.Contains(name, "adidas") or Text.Contains(name, "under armour") or Text.Contains(name, "shirt") or Text.Contains(name, "shorts") or Text.Contains(name, "dress") then "Apparel"
		        else if Text.Contains(name, "watch") or Text.Contains(name, "gps") or Text.Contains(name, "polar") or Text.Contains(name, "garmin") or Text.Contains(name, "fitbit") or Text.Contains(name, "gopro") or Text.Contains(name, "camera") or Text.Contains(name, "laptop") then "Electronics & Gadgets"
		        else if Text.Contains(name, "elliptical") or Text.Contains(name, "gym") or Text.Contains(name, "dumbbells") or Text.Contains(name, "bike") or Text.Contains(name, "training mask") or Text.Contains(name, "fit") then "Fitness & Training"
		        else if Text.Contains(name, "kayak") or Text.Contains(name, "backpack") or Text.Contains(name, "hammock") or Text.Contains(name, "tent") then "Outdoor & Adventure"
		        else "General Merchandise" 
		in
		    category),
		    #"Renamed Columns2" = Table.RenameColumns(#"Added New Category Column",{{"Custom", "Product Category"}}),
		    #"Remove Customer Password & Customer Email" = Table.RemoveColumns(#"Renamed Columns2",{"Customer Email", "Customer Password"}),
		    #"Remove Customer With State Error & null in Customer ZipCode" = Table.SelectRows(#"Remove Customer Password & Customer Email", each ([Customer City] <> "CA")),
		    #"Changed Customer Zipcode to Text" = Table.TransformColumnTypes(#"Remove Customer With State Error & null in Customer ZipCode",{{"Customer Zipcode", type text}}),
		    #"Standardized Customer Zipcode to 5 digits" = Table.AddColumn(#"Changed Customer Zipcode to Text", "Custom", each Text.PadStart([Customer Zipcode], 5, "0")),
		    #"Remove Old Customer Zipcode" = Table.RemoveColumns(#"Standardized Customer Zipcode to 5 digits",{"Customer Zipcode"}),
		    #"Renamed Columns4" = Table.RenameColumns(#"Remove Old Customer Zipcode",{{"Custom", "Customer Zipcode"}}),
		    #"Merged Queries" = Table.NestedJoin(#"Renamed Columns4", {"Order Country"}, #"Country Translation", {"Country(Spanish)"}, "Table", JoinKind.LeftOuter),
		    #"Using Country in English" = Table.ExpandTableColumn(#"Merged Queries", "Table", {"Country(English)"}, {"Table.Country(English)"}),
		    #"Removed Order Country ( Spanish )" = Table.RemoveColumns(#"Using Country in English",{"Order Country"}),
		    #"Renamed Columns3" = Table.RenameColumns(#"Removed Order Country ( Spanish )",{{"Table.Country(English)", "Order Country"}}),
		    #"Reordered Columns1" = Table.ReorderColumns(#"Renamed Columns3",{"Payment Type", "Days for shipping (real)", "Days for shipment (scheduled)", "Benefit per order", "Sales per customer", "Delivery Status", "Customer City", "Customer Country", "Customer Fname", "Customer Id", "Customer Lname", "Customer Segment", "Customer State", "Customer Street", "Customer Zipcode", "Latitude", "Longitude", "Market", "Order City", "Order Customer Id", "order date (DateOrders)", "Order Id", "Order Item Cardprod Id", "Order Item Discount", "Order Item Discount Rate", "Order Item Id", "Order Item Product Price", "Order Item Profit Ratio", "Order Item Quantity", "Sales", "Order Item Total", "Order Profit Per Order", "Order Region", "Order Country", "Order State", "Order Status", "Order Zipcode", "Product Card Id", "Product Name", "Product Price", "Product Status", "shipping date (DateOrders)", "Shipping Mode", "Product Category"}),
		    #"Capitalized Order Status" = Table.TransformColumns(#"Reordered Columns1",{{"Order Status", Text.Proper, type text}}),
		    #"Removed ""_"" in Order Status" = Table.ReplaceValue(#"Capitalized Order Status","_"," ",Replacer.ReplaceText,{"Order Status"}),
		    #"Removed Order Zipcode" = Table.RemoveColumns(#"Removed ""_"" in Order Status",{"Order Zipcode"}),
		    #"Changed Shipping & Order Date from Date/Time to Date" = Table.TransformColumnTypes(#"Removed Order Zipcode",{{"order date (DateOrders)", type date}, {"shipping date (DateOrders)", type date}}),
		    #"Renamed Shipping & Order Date Columns" = Table.RenameColumns(#"Changed Shipping & Order Date from Date/Time to Date",{{"order date (DateOrders)", "Order Date"}, {"shipping date (DateOrders)", "Shipping Date"}}),
		    #"Changed Key ID to Text" = Table.TransformColumnTypes(#"Renamed Shipping & Order Date Columns",{{"Customer Id", type text}, {"Order Customer Id", type text}, {"Order Id", type text}, {"Order Item Cardprod Id", type text}, {"Order Item Id", type text}, {"Product Card Id", type text}}),
		    #"Rounded Order Items Number & Sales Number to 2 Decimal Places" = Table.TransformColumns(#"Changed Key ID to Text",{{"Benefit per order", each Number.Round(_, 2), type number}, {"Sales per customer", each Number.Round(_, 2), type number}, {"Order Item Discount", each Number.Round(_, 2), type number}, {"Order Item Discount Rate", each Number.Round(_, 2), type number}, {"Order Item Product Price", each Number.Round(_, 2), type number}, {"Order Item Profit Ratio", each Number.Round(_, 2), type number}, {"Sales", each Number.Round(_, 2), type number}, {"Order Item Total", each Number.Round(_, 2), type number}, {"Order Profit Per Order", each Number.Round(_, 2), type number}, {"Product Price", each Number.Round(_, 2), type number}}),
		    #"Removed Product Status" = Table.RemoveColumns(#"Rounded Order Items Number & Sales Number to 2 Decimal Places",{"Product Status"})
		in
		    #"Removed Product Status"
		```
	lineageTag: a8ab610c-60fe-4bd8-815d-3514d360e7f1
	queryGroup: main

