model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup root

	annotation PBI_QueryGroupOrder = 0

queryGroup main

	annotation PBI_QueryGroupOrder = 1

queryGroup 'dim & fact'

	annotation PBI_QueryGroupOrder = 2

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["DataCoTransRoot","DataCoTransMain","Country Translation","dim_customer","dim_product","dim_order_location","fact_sales"]

annotation PBI_ProTooling = ["DevMode"]

ref table dim_customer
ref table dim_product
ref table dim_order_location
ref table fact_sales
ref table dim_date
ref table measure_table

ref cultureInfo en-US

